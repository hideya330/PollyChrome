# ==========================================
# 画像・バイナリファイル
# AIがテキストとして解析できず、トークンを無駄に消費するだけなので除外
# ==========================================
extension/icons/
*.png
*.jpg
*.jpeg
*.ico
*.zip
terraform/lambda.zip

# ==========================================
# シークレット情報
# APIキーなどが含まれるため、AIのコンテキストに送るべきではないファイル
# ==========================================
extension/config.js
*.tfvars
*.tfvars.json

# ==========================================
# 自動生成されるインフラ状態ファイル・キャッシュ
# コードの「意図」をAIに理解させる上では不要であり、
# かつファイルサイズが巨大になりがちなため除外
# ==========================================
.terraform/
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
__pycache__/
*.pyc

# ==========================================
# OS・エディタのシステムファイル
# ==========================================
.DS_Store
.vscode/